<!-- Scene: Marsim cave -->
<!-- Angle Unit: degree -->
<launch>
	<arg name="map_size_x" default="224.0" />
	<arg name="map_size_y" default="352.0" />
	<arg name="map_size_z" default="48.0" />
	<arg name="drone_id" />
	<arg name="drone_num" />
	<arg name="odom_topic" />
	<arg name="cloud_topic" />
	<arg name="frame_id" />
	<arg name="max_vel" default="5.0" />
	<arg name="max_acc" default="2.0" />
	<arg name="mount_pitch" default="45" />

	<!-- main node -->
	<node pkg="exploration_manager" name="exploration_node_$(arg drone_id)" type="exploration_node"
		output="screen">
		<!-- Input and Output Setting -->
		<remap from="/odom_world" to="$(arg odom_topic)" />
		<remap from="/map_ros/odom" to="$(arg odom_topic)" />
		<remap from="/map_ros/cloud" to="$(arg cloud_topic)" />

		<remap from="/planning/replan" to="/planning/replan_$(arg drone_id)" />
		<remap from="/planning/new" to="/planning/new_$(arg drone_id)" />
		<remap from="/planning/bspline" to="/planning/bspline_$(arg drone_id)" />

		<remap from="/sdf_map/occupancy_all" to="uav$(arg drone_id)/sdf_map/occupancy_all" />
		<remap from="/sdf_map/quality_all" to="uav$(arg drone_id)/sdf_map/quality_all" />
		<remap from="/sdf_map/free_all" to="uav$(arg drone_id)/sdf_map/free_all" />
		<remap from="/sdf_map/inflate_occupancy_all" to="uav$(arg drone_id)/sdf_map/inflate_occupancy_all" />
		
		<remap from="/swarm_expl/drone_state_send" to="/swarm_expl/drone_state" />
		<remap from="/swarm_expl/drone_state_recv" to="/swarm_expl/drone_state" />

		<!-- plan_env -->
		<param name="sdf_map/resolution" value="0.5" />
		<param name="sdf_map/map_size_x" value="$(arg map_size_x)" />
		<param name="sdf_map/map_size_y" value="$(arg map_size_y)" />
		<param name="sdf_map/map_size_z" value="$(arg map_size_z)" />
		<param name="sdf_map/x_offset" value="70.0" />
		<param name="sdf_map/y_offset" value="-50.0" />
		<param name="sdf_map/obstacles_inflation" value="0.5" />
		<param name="sdf_map/local_bound_inflate" value="0.5" />
		<param name="sdf_map/ground_height" value="-8" />
		<param name="sdf_map/default_dist" value="99.0" />
		<param name="sdf_map/p_hit" value="0.75" /> 
		<param name="sdf_map/p_miss" value="0.35" />
		<param name="sdf_map/p_min" value="0.12" />
		<param name="sdf_map/p_max" value="0.90" />
		<param name="sdf_map/p_occ" value="0.80" />
		<param name="sdf_map/max_ray_length" value="40" />
		<param name="sdf_map/min_ray_length" value="0.3" />
		<param name="sdf_map/virtual_ceil_height" value="-20" />
		<param name="sdf_map/optimistic" value="false" type="bool" />
		<param name="sdf_map/signed_dist" value="false" type="bool" />
		<param name="sdf_map/box_min_x" value="-42.0" type="double" />
		<param name="sdf_map/box_min_y" value="-226.0" type="double" />
		<param name="sdf_map/box_min_z" value="-8.0" type="double" />
		<param name="sdf_map/box_max_x" value="182.0" type="double" />
		<param name="sdf_map/box_max_y" value="126.0" type="double" />
		<param name="sdf_map/box_max_z" value="40.0" type="double" />
		<param name="sdf_map/esdf_range_x" value="8" type="double" />
		<param name="sdf_map/esdf_range_y" value="8" type="double" />
		<param name="sdf_map/esdf_range_z" value="5" type="double" />

		<param name="sdf_map/raycast_type" value="1" type="int" />
		<param name="sdf_map/raycast_with_fov" value="true" type="bool" />
		<param name="sdf_map/raycast_cos_threshold" value="0.5" type="double" />
		<param name="sdf_map/raycast_cos_threshold2" value="0.7" type="double" />
		<param name="sdf_map/raycast_dist_threshold" value="5.0" type="double" />
		<param name="sdf_map/pointcloud_buffer_length" value="5" type="int" />

		<param name="sdf_map/ignore_height" value="1.0" type="double" />
		<param name="sdf_map/normal_search_num" value="10" type="int" />
		<param name="sdf_map/leaf_size" value="0.5" type="double" />


		<param name="map_ros/visualization_truncate_height" value="40" />
		<param name="map_ros/visualization_truncate_low" value="-20" />
		<param name="map_ros/show_all_map" value="true" />
		<param name="map_ros/frame_id" value="$(arg frame_id)" />
		<param name="map_ros/cloud_frame_type" value="2" />

		<!-- Fsm -->
		<param name="fsm/replan_time" value="0.3" type="double" />
		<param name="fsm/frame_id" value="$(arg frame_id)" />
		<param name="fsm/hgrid_enable" value="true" type="bool" />
		<param name="fsm/return_home" value="false" type="bool" />
		<param name="fsm/search_frt_interval" value="0.5" type="double" />


		<param name="partitioning/min_frontier" value="100" type="int" />
		<param name="partitioning/min_unknown_percent" value="0.3" type="double" />
		<param name="partitioning/min_free_percent" value="1.0" type="double" />
		<param name="partitioning/consistent_cost" value="-5" type="double" />
		<param name="partitioning/consistent_cost2" value="8" type="double" />
		<param name="partitioning/w_unknown" value="0.0" type="double" />
		<param name="partitioning/grid_size" value="32.0" type="double" />
		<param name="partitioning/grid_height" value="24.0" type="double" />

		<param name="hgrid/unknown_percent_thresh" value="0.05" type="double" />
		<param name="hgrid/coefficient_vel_cost" value="1.0" type="double" />
		<param name="hgrid/coefficient_frt_cost" value="1.0" type="double" />


		<!-- Exploration manager -->
		<param name="exploration/max_decay" value="0.8" type="double" />
		<param name="exploration/top_view_num" value="15" type="int" />
		<param name="exploration/vm" value="$(eval 1.0 * arg('max_vel'))" type="double" />
		<param name="exploration/am" value="$(eval 1.0 * arg('max_acc'))" type="double" />
		<param name="exploration/yd" value="$(eval 80 * 3.1415926 / 180.0)" type="double" />
		<param name="exploration/ydd" value="$(eval 120 * 3.1415926 / 180.0)" type="double" />
		<param name="exploration/drone_num" value="$(arg drone_num)" type="double" />
		<param name="exploration/drone_id" value="$(arg drone_id)" type="int" />
		<param name="exploration/init_plan_num" value="2" type="int" />
		<param name="exploration/tsp_dir" value="$(find lkh_tsp_solver)/resource" type="string" />
    	<param name="exploration/mtsp_dir" value="$(find lkh_mtsp_solver)/resource" type="string"/>
		<param name="exploration/traj_segment_length" value="20.0" type="double" />


		<!-- planner manager -->
		<!-- <param name="manager/max_vel" value="$(arg max_vel)" type="double"/> -->
		<param name="manager/max_vel" value="$(arg max_vel)" type="double" />
		<param name="manager/max_acc" value="$(arg max_acc)" type="double" />
		<param name="manager/max_jerk" value="4" type="double" />
		<param name="manager/dynamic_environment" value="0" type="int" />
		<param name="manager/clearance_threshold" value="0.2" type="double" />
		<param name="manager/control_points_distance" value="1.5" type="double" />
		<param name="manager/use_geometric_path" value="true" type="bool" />
		<param name="manager/use_kinodynamic_path" value="true" type="bool" />
		<param name="manager/use_topo_path" value="false" type="bool" />
		<param name="manager/use_optimization" value="true" type="bool" />
		<param name="manager/use_active_perception" value="true" type="bool" />
		<param name="manager/min_time" value="true" type="bool" />
		<param name="manager/relax_time1" value="0.3" type="double" />
		<param name="manager/relax_time2" value="1.5" type="double" />
		<param name="manager/max_yawdot" value="$(eval 90 * 3.1415926 / 180.0)" type="double" />

		<!-- kinodynamic path searching -->
		<param name="search/max_tau" value="1.0" type="double" />
		<param name="search/init_max_tau" value="1.0" type="double" />
		<param name="search/max_vel" value="$(arg max_vel)" type="double" />
		<param name="search/vel_margin" value="0.25" type="double" />
		<param name="search/max_acc" value="$(arg max_acc)" type="double" />
		<param name="search/w_time" value="50.0" type="double" />
		<param name="search/horizon" value="10.0" type="double" />
		<param name="search/lambda_heu" value="10.0" type="double" />
		<param name="search/resolution_astar" value="0.5" type="double" />
		<param name="search/time_resolution" value="0.8" type="double" />
		<param name="search/margin" value="1.0" type="double" />
		<param name="search/allocate_num" value="100000" type="int" />
		<param name="search/check_num" value="10" type="int" />
		<param name="search/optimistic" value="false" type="bool" />

		<param name="astar/lambda_heu" value="100.0" type="double" />
		<param name="astar/resolution_astar" value="1.0" type="double" />
		<param name="astar/allocate_num" value="1000000" type="int" />
		<param name="astar/max_search_time" value="0.1" type="double" />

		<!-- trajectory optimization -->
		<param name="optimization/ld_smooth" value="10.0" type="double" />
		<param name="optimization/ld_dist" value="80.0" type="double" />
		<param name="optimization/ld_feasi" value="2.0" type="double" />
		<param name="optimization/ld_start" value="100.0" type="double" />
		<param name="optimization/ld_end" value="200.0" type="double" />
		<param name="optimization/ld_guide" value="1.5" type="double" />
		<param name="optimization/ld_waypt" value="70.0" type="double" />
		<param name="optimization/ld_view" value="0.0" type="double" />
		<param name="optimization/ld_time" value="80" type="double" />
		<param name="optimization/ld_swarm" value="5.0" type="double" />
		<param name="optimization/swarm_safe_dist" value="1.0" type="double" />
		<param name="optimization/dist0" value="0.7" type="double" />
		<param name="optimization/max_vel" value="$(arg max_vel)" type="double" />
		<param name="optimization/max_acc" value="$(arg max_acc)" type="double" />
		<param name="optimization/algorithm1" value="15" type="int" />
		<param name="optimization/algorithm2" value="11" type="int" />
		<param name="optimization/max_iteration_num1" value="2" type="int" />
		<param name="optimization/max_iteration_num2" value="2000" type="int" />
		<param name="optimization/max_iteration_num3" value="200" type="int" />
		<param name="optimization/max_iteration_num4" value="200" type="int" />
		<param name="optimization/max_iteration_time1" value="0.0001" type="double" />
		<param name="optimization/max_iteration_time2" value="0.005" type="double" />
		<param name="optimization/max_iteration_time3" value="0.003" type="double" />
		<param name="optimization/max_iteration_time4" value="0.003" type="double" />

		<!-- Other -->
		<param name="general/marker_scale" value="1.0" type="double" />
		<param name="general/frame_id" value="$(arg frame_id)" />

		<!-- perception_utils_lidar -->
		<param name="perception_utils_lidar/max_radius" value="30.0" type="double" />
		<param name="perception_utils_lidar/min_radius" value="0.5" type="double" />
		<param name="perception_utils_lidar/mount_yaw" value="0.0" type="double" />
		<param name="perception_utils_lidar/mount_pitch" value="$(arg mount_pitch)" type="double" />
		<param name="perception_utils_lidar/mount_roll" value="0.0" type="double" />
		<param name="perception_utils_lidar/theta_min" value="-10.0" type="double" />
		<param name="perception_utils_lidar/theta_max" value="44.0" type="double" />
		<param name="perception_utils_lidar/phi_min" value="-180.0" type="double" />
		<param name="perception_utils_lidar/phi_max" value="180.0" type="double" />

		<param name="/perception_utils_lidar/lidar_mount_x" value="0.2" type="double" />
		<param name="/perception_utils_lidar/lidar_mount_y" value="0.0" type="double" />
		<param name="/perception_utils_lidar/lidar_mount_z" value="0.12" type="double" />
		<param name="/perception_utils_lidar/search_radius" value="1" type="int" />
		<param name="/perception_utils_lidar/frame_id" value="$(arg frame_id)" />

		<param name="perception_utils_lidar/read_calibration" value="false" type="bool"/>
        <param name="perception_utils_lidar/cfg_dir" value="$(find lidar)/cfg" type="string"/>

		<!-- frontier_finder -->
		<param name="frontier_finder/threshold_max" value="0.2" type="double" />
		<param name="frontier_finder/well_observed" value="0.1" type="double" />
		<param name="frontier_finder/threshold_min" value="0" type="double" />
		<param name="frontier_finder/dist_threshold" value="5.0" type="double" />
		<param name="frontier_finder/min_quality_av" value="0.5" type="double" />
		<param name="frontier_finder/search_step" value="2" type="int" />
		<param name="frontier_finder/dynamic_frontier" value="true" type="bool" />
		<param name="frontier_finder/force_eliminate" value="false" type="bool" />

		<param name="frontier/cluster_min" value="10" type="int" />
		<param name="frontier/cluster_size_xy" value="5.0" type="double" />
    	<param name="frontier/cluster_size_z" value="8.0" type="double" />
		<param name="frontier/min_candidate_dist" value="10.0" type="double" />
		<param name="frontier/min_candidate_clearance" value="0.3" type="double" />
		<param name="frontier/candidate_dphi" value="$(eval 30 * 3.1415926 / 180.0)" type="double" />
		<param name="frontier/candidate_rnum" value="5" type="int" />
		<param name="frontier/candidate_rmin" value="0.5" type="double" />
		<param name="frontier/candidate_rmax" value="5.0" type="double" />
		<param name="frontier/candidate_hnum" value="4" type="int" />
		<param name="frontier/candidate_hmin" value="-3.0" type="double" />
		<param name="frontier/candidate_hmax" value="3.0" type="double" />
		<param name="frontier/min_visib_num" value="6" type="int" />
		<param name="frontier/min_visib_percent" value="0.6" type="double" />
		<param name="frontier/ignore_height" value="-100.0" type="double" />
		<param name="frontier/ignore_height_up" value="100.0" type="double" />


		<param name="frontier/vm" value="$(eval 1.0 * arg('max_vel'))" type="double" />
		<param name="frontier/am" value="$(eval 1.0 * arg('max_acc'))" type="double" />
		<param name="frontier/yd" value="$(eval 90 * 3.1415926 / 180.0)" type="double" />
		<param name="frontier/ydd" value="$(eval 90 * 3.1415926 / 180.0)" type="double" />
		<param name="frontier/w_dir" value="1.5" type="double" />
		<param name="frontier/frame_id" value="$(arg frame_id)" />

	</node>

	<!-- trajectory server -->
	<node pkg="plan_manage" name="traj_server_$(arg drone_id)" type="traj_server" output="screen">
		<remap from="/odom_world" to="$(arg odom_topic)" />
		<remap from="/planning/bspline" to="/planning/bspline_$(arg drone_id)" />
		<remap from="/planning/replan" to="/planning/replan_$(arg drone_id)" />
		<remap from="/position_cmd1" to="/planning/pos_cmd" />
		<remap from="/position_cmd2" to="/planning/pos_cmd_$(arg drone_id)" />
		<remap from="planning/position_cmd_vis" to="/planning/position_cmd_vis_$(arg drone_id)" />
		<remap from="planning/travel_traj" to="/planning/travel_traj_$(arg drone_id)" />
		<param name="traj_server/time_forward" value="1.5" type="double" />
		<param name="traj_server/pub_traj_id" value="4" type="int" />
		<param name="traj_server/drone_id" value="$(arg drone_id)" type="int" />
		<param name="traj_server/drone_num" value="$(arg drone_num)" type="int" />
		<param name="general/frame_id" value="$(arg frame_id)" />
	</node>

	<node pkg="lkh_mtsp_solver" name="tsp_solver_$(arg drone_id)" type="mtsp_node" output="log">
		<param name="exploration/drone_id" value="$(arg drone_id)" type="int"/>
		<param name="exploration/mtsp_dir" value="$(find lkh_mtsp_solver)/resource" type="string"/>
		<param name="exploration/problem_id" value="1" type="int"/>
	</node>
	
</launch>